rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isActiveLecturer() {
      return exists(/databases/$(database)/documents/lecturers/$(request.auth.uid))
        && get(/databases/$(database)/documents/lecturers/$(request.auth.uid)).data.status == 'active';
    }

    function lecturerCanReadStudent() {
      let lecturer = get(/databases/$(database)/documents/lecturers/$(request.auth.uid)).data;
      return lecturer.status == 'active'
        && (lecturer.school == null || lecturer.school == resource.data.faculty);
    }

    function isStudent(safeId) {
      return request.auth.token.matricNo.replace('/', '-') == safeId;
    }

    // Students collection
    match /students/{safeId} {
      allow read: if isAdmin() || lecturerCanReadStudent() || isStudent(safeId);
      allow update: if isStudent(safeId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['matricNo','fullName','department','faculty','cgpa','level','lastUmisSyncAt']);
      allow create: if false;  // Only created by UMIS proxy flow
      allow delete: if false;

      // Private subcollection — password hashes. No client access whatsoever.
      match /private/{document} {
        allow read, write: if false;
      }
    }

    // Sync metadata — admin read-only
    match /meta/{document} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Lecturers collection
    match /lecturers/{uid} {
      allow read: if isAdmin() || request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // Admins collection
    match /admins/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if false;  // Seeded manually
    }
  }
}
